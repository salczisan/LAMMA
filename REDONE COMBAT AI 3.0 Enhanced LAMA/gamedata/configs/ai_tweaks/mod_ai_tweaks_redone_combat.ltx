;---------------------------------------------------------------
; NPC Detection & Sound Awareness Explanation
;---------------------------------------------------------------
; All NPC detection values listed below are expressed in meters.
;
; These distances define how far an NPC can detect the player 
; depending on the player's movement type (sneak, walk, run, sprint)
; and whether the player's flashlight is on (torch_day / torch_night).
;
; Detection values are multiplied by the NPC's rank multiplier:
;---------------------------------------------------------------
; NPC Detection Awareness Rank Multipliers
;---------------------------------------------------------------

@[npc_detection_rank]
v_0 = 0.5   ; novice
v_1 = 0.525 ; trainee
v_2 = 0.55  ; experienced
v_3 = 0.575 ; professional
v_4 = 0.6   ; expert
v_5 = 0.65  ; veteran
v_6 = 0.7   ; master
v_7 = 0.75  ; legend
special = 0.5

;---------------------------------------------------------------
; NPC Detection Base distances per rank
;---------------------------------------------------------------

@[novice] ; rank + 0 * rank
sneak  = 8  ;0 +0
walk   = 10 ;0 +0
run    = 12 ;0 +0
sprint = 18 ;0 +0
torch_day   = 24 ;0 +0
torch_night = 42 ;0 +0
fog_factor  = 0.9
rain_factor = 0.7


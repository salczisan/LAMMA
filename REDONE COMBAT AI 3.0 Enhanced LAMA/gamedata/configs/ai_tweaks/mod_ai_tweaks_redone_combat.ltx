;---------------------------------------------------------------
; NPC Sound Awareness Explanation
;---------------------------------------------------------------
; NPC Sound Awareness determines how far NPCs can detect the player 
; or events based on sound types (weapons, movement, items, etc.).
; 
; Each NPC rank also has a multiplier affecting hearing distance:
; 
; Each sound type (WPN_shoot, WPN_reload, MST_step, etc.) has its own 
; multiplier that further scales the effective hearing distance.
; 
; Weather conditions also modify hearing distance via the following multipliers:
; 
; Effective NPC hearing distance = Base sound type distance 
;                               * NPC rank multiplier 
;                               * Weather multiplier
;---------------------------------------------------------------
; NPC Sound Awareness Rank Multipliers
;---------------------------------------------------------------

@[npc_sound_awareness_rank]
v_0 = 1.00 ; Novice
v_1 = 1.05 ; Trainee
v_2 = 1.10 ; Experienced
v_3 = 1.15 ; Professional
v_4 = 1.20 ; Expert
v_5 = 1.25 ; Veteran
v_6 = 1.30 ; Master
v_7 = 1.35 ; Legend
special = 1.0

;---------------------------------------------------------------
; NPC Sound Awareness Multipliers
;---------------------------------------------------------------

@[npc_sound_awareness_type]
v_0  = 1.5  ; WPN_shoot
v_1  = 1.4  ; WPN_reload
v_2  = 0.9  ; WPN_empty
v_3  = 1.2  ; WPN_hit
v_4  = 1.0  ; WPN_show
v_5  = 1.0  ; WPN_hide
v_6  = 0.8  ; MST_attack
v_7  = 0.8  ; MST_damage
v_8  = 0.4  ; MST_step
v_9  = 0.6  ; MST_talk
v_10 = 0.6  ; MST_die
v_11 = 0.4  ; MST_eat
v_12 = 0.9  ; ITM_pckup
v_13 = 0.9  ; ITM_drop
v_14 = 0.9  ; ITM_hide
v_15 = 0.9  ; ITM_take
v_16 = 1.0  ; ITM_use
special = 1.0

;---------------------------------------------------------------
; Weather multipliers for NPC hearing
;---------------------------------------------------------------

@[npc_sound_weather]
clear      = 1.0  ; Default clear weather
light_rain = 0.8  ; Light rain slightly reduces hearing
heavy_rain = 0.6  ; Heavy rain strongly reduces hearing
foggy      = 0.9  ; Foggy weather reduces hearing moderately
storm      = 0.6  ; Storm (treated like heavy rain for clarity)

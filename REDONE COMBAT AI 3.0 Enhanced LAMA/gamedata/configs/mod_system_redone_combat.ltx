; Formula for Visibility
;Value = time_delta / time_quant * luminocity_factor * (1.f + velocity_factor*object_velocity) * (distance - object_distance) / (distance - always_visible_distance)
;Value >= visibility_threshold

;transparency_threshold is done during ray_query
;Note that improper values, no matter how high transparency_threshold will result in stalkers shooting at walls

![stalker_vision_free]
min_view_distance		= 0.18		;min range of cone based on eye_range
max_view_distance		= 1.15		;max range of cone based on eye_range
visibility_threshold		= 130.0 	;Threshold in which object becomes visible based on factors
always_visible_distance 	= 0.05		;Distance object is always considered visible (float)
time_quant			= 0.40		;step increment to for sight calculations
decrease_value			= 0.02   	;Decrease over time to overall threshold
velocity_factor			= 0.8		;Higher value = greater bonus to detection speed when target is moving (depended on movement speed)
luminocity_factor		= 0.85		;Low value = easier to see at night
transparency_threshold		= 0.70		;Low value = easier to see through objects
still_visible_time		= 300		;The time (milliseconds) that the object is still considered visible , even if it is not in the frustum (u32)

![stalker_vision_danger]
min_view_distance   	        = 0.22		; min range of cone based on eye_range
max_view_distance	 	= 1.85	  	; max range of cone based on eye_range
visibility_threshold		= 60.0 		;Threshold in which object becomes visible based on factors
always_visible_distance 	= 0.05		;Distance object is always considered visible (float)
time_quant			= 0.75		;step increment to for sight calculations
decrease_value			= 0.015		;Decrease over time to overall threshold
velocity_factor			= 0.90		;Higher value = greater bonus to detection speed when target is moving (depended on movement speed)
luminocity_factor		= 0.60		;Low value = easier to see at night
transparency_threshold		= 0.61		;Low value = easier to see through objects (if greater then 1 then enemies are blind)
still_visible_time		= 700		;The time (milliseconds) that the object is still considered visible , even if it is not in the frustum (u32)


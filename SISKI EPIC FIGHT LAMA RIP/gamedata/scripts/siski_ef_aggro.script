-- siski_ef_aggro.script
-- OPTIMIZED FOR CENTRAL DISPATCH

local aggro = {}

--------------------------------------------------------
-- CONFIG
--------------------------------------------------------

local AGGRO_DISTANCE = 40

--------------------------------------------------------
-- UPDATE
--------------------------------------------------------

function aggro.update(context)

    if not context.enemy then
        return false
    end

    if not context.enemy:alive() then
        return false
    end

    if not context.distance then
        return false
    end

    -- poza zasięgiem presji
    if context.distance > AGGRO_DISTANCE then
        return false
    end

    -- brak LOS = nie naciskamy
    if not context.has_los then
        return false
    end

    ----------------------------------------------------
    -- AGGRESSIVE PRESSURE LOGIC
    ----------------------------------------------------

    -- nie ustawiamy enemy
    -- nie resetujemy FSM
    -- tylko wpływamy na zachowanie

    context.object:set_desired_direction(context.enemy:position())

    return true
end

--------------------------------------------------------

return aggro
-- siski_ef_flee.script
-- STABLE TACTICAL FLEE FOR DISPATCH SYSTEM

local flee = {}

--------------------------------------------------------
-- CONFIG
--------------------------------------------------------

local FLEE_DURATION = 3000  -- ms
local MIN_FLEE_DISTANCE = 15

--------------------------------------------------------
-- STATE CACHE
--------------------------------------------------------

local _flee_until = {}

local function now()
    return time_global()
end

--------------------------------------------------------
-- HELPERS
--------------------------------------------------------

local function is_monolith(obj)
    return obj:character_community() == "monolith"
end

local function is_zombie(obj)
    return obj:character_community() == "zombied"
end

--------------------------------------------------------
-- UPDATE
--------------------------------------------------------

function flee.update(context)

    local obj = context.object
    local obj_id = obj:id()

    -- nie działa dla monolith
    if is_monolith(obj) then
        return false
    end

    -- zombie nie uciekają
    if is_zombie(obj) then
        return false
    end

    ----------------------------------------------------
    -- ACTIVE FLEE LOCK
    ----------------------------------------------------

    if _flee_until[obj_id] and now() < _flee_until[obj_id] then

        if context.enemy then
            -- utrzymuj dystans
            obj:set_desired_direction(obj:position() - context.enemy:position())
        end

        return true
    end

    ----------------------------------------------------
    -- START FLEE
    ----------------------------------------------------

    if not context.enemy then
        return false
    end

    if not context.distance then
        return false
    end

    if context.distance > MIN_FLEE_DISTANCE then
        return false
    end

    -- rozpocznij ucieczkę
    _flee_until[obj_id] = now() + FLEE_DURATION

    obj:set_desired_direction(obj:position() - context.enemy:position())

    return true
end

--------------------------------------------------------

return flee
-- siski_ef_anomaly.script
-- LOW PRIORITY ANOMALY AWARENESS
-- does NOT scan world, only reacts to current danger

local anomaly = {}

--------------------------------------------------------
-- CONFIG
--------------------------------------------------------

local ANOMALY_ESCAPE_TIME = 1000 -- ms

--------------------------------------------------------
-- STATE
--------------------------------------------------------

local _escape_until = {}

local function now()
    return time_global()
end

--------------------------------------------------------
-- HELPERS
--------------------------------------------------------

local function is_in_anomaly(obj)
    -- lekki check – czy obiekt dostaje obrażenia środowiskowe
    -- nie używamy raycastów ani przeszukiwania levelu
    return obj:conditions():is_burning() 
        or obj:conditions():is_radiated()
end

--------------------------------------------------------
-- UPDATE
--------------------------------------------------------

function anomaly.update(context)

    local obj = context.object
    local obj_id = obj:id()

    -- jeśli flee lub close combat przejęło kontrolę
    if context.enemy and context.has_los and context.distance and context.distance < 12 then
        return false
    end

    ----------------------------------------------------
    -- ACTIVE ESCAPE
    ----------------------------------------------------

    if _escape_until[obj_id] and now() < _escape_until[obj_id] then
        return true
    end

    ----------------------------------------------------
    -- DETECT ANOMALY
    ----------------------------------------------------

    if not is_in_anomaly(obj) then
        return false
    end

    ----------------------------------------------------
    -- START ESCAPE BURST
    ----------------------------------------------------

    _escape_until[obj_id] = now() + ANOMALY_ESCAPE_TIME

    -- krótki ruch w losowym kierunku
    local pos = obj:position()
    local offset = vector():set(math.random(-3,3), 0, math.random(-3,3))
    obj:set_desired_direction(pos + offset)

    return true
end

--------------------------------------------------------

return anomaly
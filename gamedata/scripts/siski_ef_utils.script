-- Siski Epic Fight - Утилиты Расширенного ИИ
-- Логика расчета силы отряда и общие вспомогательные функции
-- Портировано из мода npc_fleeing_0.33


-- ==============================================================================================
-- ULTRA SAFE HELPERS (Prevent CScriptEntity : cannot access class member Alive!)
-- ==============================================================================================

function is_alive(obj)
    if not obj then return false end
    local ok, res = pcall(function() return obj:alive() end)
    return ok and res
end

function get_health(obj)
    if not obj then return 0 end
    local ok, res = pcall(function() return obj:health() end)
    return ok and res or 0
end

function safe_is_wounded(npc)
    if not is_alive(npc) then return false end
    local ok, res = pcall(function() return IsWounded(npc) end)
    return ok and res
end

function safe_best_enemy(npc)
    if not is_alive(npc) then return nil end
    local ok, res = pcall(function() return npc:best_enemy() end)
    return ok and res or nil
end

function safe_best_danger(npc)
    if not is_alive(npc) then return nil end
    local ok, res = pcall(function() return npc:best_danger() end)
    return ok and res or nil
end

function safe_movement_type(npc)
    if not is_alive(npc) then return nil end
    local ok, res = pcall(function() return npc:movement_type() end)
    return ok and res or nil
end

function safe_in_restrictions(npc)
    if not is_alive(npc) then return "" end
    local ok, res = pcall(function() return npc:in_restrictions() end)
    return ok and res or ""
end

function safe_has_info(npc, info)
    if not is_alive(npc) then return false end
    local ok, res = pcall(function() return npc:has_info(info) end)
    return ok and res
end

function can_panic(npc)
    local sfind = string.find
    if not (npc and IsStalker(npc) and is_alive(npc)) then return false end
    
    local id = npc:id()
    
    -- [NEW] Check for Engine Busy States
    local ok_busy, res_busy = pcall(function()
        if npc:is_talking() then return true end
        
        local st = db.storage[id]
        if st and st.active_scheme then
            local scheme = st.active_scheme
            if scheme == "meet" or scheme == "anim" or scheme == "salut" or scheme == "remark" then
                return true
            end
        end
        return false
    end)
    
    if ok_busy and res_busy then return false end

    if safe_is_wounded(npc) then return false end
    
    local visual = ""
    local ok_v, res_v = pcall(function() return npc:get_visual_name() end)
    if ok_v then visual = res_v:lower() end
    
    if sfind(visual, "zombie") or sfind(visual, "mutant") or sfind(visual, "ghost") then
        return false
    end
    
    if sfind(visual, "actors\\") then
        return true
    end
    
    return false
end



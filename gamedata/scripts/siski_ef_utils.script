----------------------------------------------------------------------
-- GLOBAL AI STABILITY PATCH
-- (safe addition, does not modify original systems)
----------------------------------------------------------------------

-- cooldown decyzji NPC (1 sekunda)
npc_decision_cooldown = {}

function can_npc_think(npc_id)

    local t = time_global()

    if npc_decision_cooldown[npc_id] == nil then
        npc_decision_cooldown[npc_id] = t
        return true
    end

    if (t - npc_decision_cooldown[npc_id]) > 1000 then
        npc_decision_cooldown[npc_id] = t
        return true
    end

    return false
end


-- blokada zmiany stanu (stabilizacja AI)
npc_state_lock = {}

function lock_npc_state(npc_id)
    npc_state_lock[npc_id] = time_global()
end

function is_state_locked(npc_id)

    local t = npc_state_lock[npc_id]

    if not t then
        return false
    end

    return (time_global() - t) < 2000
end


-- shared cache dla systemów cover
shared_cover_cache = {}
shared_cover_cache_time = {}

function get_cached_cover(id)

    local t = shared_cover_cache_time[id]

    if not t then return nil end

    if (time_global() - t) > 2000 then
        shared_cover_cache[id] = nil
        shared_cover_cache_time[id] = nil
        return nil
    end

    return shared_cover_cache[id]
end

function set_cached_cover(id,val)

    shared_cover_cache[id] = val
    shared_cover_cache_time[id] = time_global()

end


function is_safe_mode()
    return false
end
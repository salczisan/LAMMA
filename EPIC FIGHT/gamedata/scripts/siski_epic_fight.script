        return false
    end
}

-- FLANK EVENT
Events.Flank = {
    id = "flank",
    action = function(self, npc)
        if active_states[npc:id()] then return false end
        local enemy = npc:best_enemy()
        if not enemy then return false end
         
        -- 50% chance to find cover INSTEAD (User: "search cover before flanking")
        -- Wait, user said: "with 50% chance ... searches cover before flanking as in p.3"
        -- This implies: Find Cover -> Then Flank? Or Just Cover?
        -- "Like in p.3" implies executing Cover Event.
        if math.random() > 0.5 then
            if Events.Cover:action(npc) then return true end
        end
        
        -- Flank Vector Calculation
        local npc_pos = npc:position()
        local enemy_pos = enemy:position()
        local dir_to_enemy = vector():set(enemy_pos.x - npc_pos.x, 0, enemy_pos.z - npc_pos.z)
        local dist = dir_to_enemy:magnitude()
        dir_to_enemy:normalize()
        
        -- Rotate 90 degrees (random left or right)
        local angle = (math.random() > 0.5) and 90 or -90
        local flank_dir = vector_rotate_y(dir_to_enemy, angle)
        
        local target_pos = vector():set(npc_pos.x + flank_dir.x * 20, npc_pos.y, npc_pos.z + flank_dir.z * 20)
        local vid = level.vertex_id(target_pos)
        
        if not vid or vid >= 4294967295 or not npc:accessible(vid) then 
            return false 
        end
        
        active_states[npc:id()] = {
             type = "flank",
             end_time = time_global() + 6000,
             target_vid = vid,
             path_set = false
        }
        
        -- [PROTECTION] Stop aggressive fire during flank
        reset_npc_forced_actions(npc)
        
        npc:clear_animations() -- Instant transition
        npc:set_path_type(game_object.level_path)
        npc:set_detail_path_type(move.line)
        npc:set_dest_level_vertex_id(vid)
        npc:set_movement_type(move.run)
        
                return true
    end,
    on_hit = function(self, npc, context)
        local chance = get_config("ef_flank_on_hit", 10)
        if math.random(100) <= chance then return self:action(npc) end
        return false
    end,
    on_tick = function(self, npc) return false end 
}

-- GRENADE EVENT (Native Hook Implementation)
-- Uses _g.update_best_weapon engine hook to force grenade selection
Events.Grenade = {
    id = "grenade",
    
    action = function(self, npc)
        local id = npc:id()
        
        -- [PROTECTION] Stop shooting to prepare grenade throw
        reset_npc_forced_actions(npc)
        
        -- 1. Per-NPC 30s cooldown for THIS event
        if grenade_cooldowns[id] and time_global() < grenade_cooldowns[id] then
            return false
        end
        
        -- 2. Tactical Context Check (CombatManager integration)
        local context = CombatManager:get_context(npc)
        if context then
            local min_enemies = get_config("ef_grenade_min_enemies", 2)
            local only_outnumbered = get_config("ef_grenade_only_outnumbered", false)
            
            -- Skip if not enough enemies
            if context.enemies < min_enemies then
                return false
            end
            
            -- Skip if "only when outnumbered" is enabled and NPC is not outnumbered
            if only_outnumbered and not context.outnumbered then
                return false
            end
        end
        
        -- 3. Find existing grenade or spawn one
        local grenade = npc:object("grenade_rgd5") or npc:object("grenade_f1")
        if not grenade then
            -- Spawn random grenade type
                        local sec = math.random() < 0.5 and "grenade_rgd5" or "grenade_f1"
            alife_create_item(sec, npc)
            printf("EVENT: GRENADE | NPC: %s | Spawned [%s], will force on next tick", npc:name(), sec)

            -- Set cooldown immediately to prevent double-spawn
            grenade_cooldowns[id] = time_global() + 30000
            return true -- Will trigger force on next tick after spawn
        end
        
        -- 4. Register for hook override
        force_grenade_npcs[id] = grenade
        
                -- 5. Start 30s cooldown
        grenade_cooldowns[id] = time_global() + 30000
        
        printf("EVENT: GRENADE | NPC: %s | Forcing via hook (enemies: %d)", 
            npc:name(), context and context.enemies or 0)
        return true

    end,
    
    on_hit = function(self, npc, context) return false end, -- Only trigger via tick
    
    on_tick = function(self, npc)
        -- Hardcoded: always attempt to throw (cooldown + tactical checks inside action())
        return self:action(npc)
    end
}

-- ENGINE HOOK: Override best_weapon selection
-- Called from C++ (ai_stalker_fire.cpp:463) every time NPC evaluates weapons
function _g.update_best_weapon(npc, current_best)
    if not npc then return nil end
    local id = npc:id()
    
    local grenade = force_grenade_npcs[id]
    if grenade then
        force_grenade_npcs[id] = nil -- One-shot: don't keep forcing after first call
                   printf("HOOK: Forcing grenade for NPC [%s]", npc:name())
        return grenade
    end
    
    return nil -- Use default engine logic
end



-- Force a specific state (Used by external modules like Anomaly Handler)
-- Force a specific state (Used by external modules like Anomaly Handler)
function force_panic_state(npc, danger_obj, duration)
    -- STRICT SAFETY CHECK
    -- [OFFLINE/DEAD RESTRICTION] Ignore offline or dead NPCs
    if not (npc and npc.online and siski_ef_utils.is_alive(npc)) then return end
    local id = npc:id()
    
    -- [NEW] Re-trigger Protection: Don't restart if already panicking
    if active_states[id] and active_states[id].type == "panic" then
        return
    end
    
    -- 1. Calculate Flee Vertex (Try Smart -> Fallback to Dumb Random)
    local vid = nil
    if siski_ef_flee then
        vid = siski_ef_flee.find_flee_vertex(npc, danger_obj)
    end
    
    -- Absolute Fallback: any vertex 15-20m away
    if not vid then
        local dir = vector_rotate_y(npc:direction(), math.random(-120, 120))
        vid = npc:vertex_in_direction(npc:level_vertex_id(), dir, 20)
    end
    
    -- Still nil? Just run to current (panic in place) implies blocked, but unlikely
    
    -- 2. Immediate Logic Override (Wrapped in pcall for safety)
        -- [NEW] Proactive Animation Check
        local mental = anim.panic
        if siski_ef_utils.can_panic and not siski_ef_utils.can_panic(npc) then
            mental = anim.danger -- Fallback for non-standard visuals
        end

        pcall(function()
            -- [REMOVED] npc:clear_animations()
            -- Rationale: clear_animations() stops engine animation sequences abruptly.
            -- If state_mgr is using an item (guitar, bread), this can cause alife_release errors/crashes.

            if vid then
                npc:set_path_type(game_object.level_path)
                npc:set_dest_level_vertex_id(vid)
            end
            
            -- FORCE BREAK ANIMATION LOOPS
            if state_mgr then
                -- 1. Stop SISKI ambient tracking (clears internal flags)
                if siski_ambient and siski_ambient.stop_ambient then
                    siski_ambient.stop_ambient(npc)
                end
                
                -- 2. Unlock state_mgr
                state_mgr.lock(npc, false) 
                
                -- 3. Transition to IDLE gently but firmly
                -- {force = true} breaks standard logic, {fast_set = true} skips transitions
                state_mgr.set_state(npc, "idle", nil, nil, nil, {fast_set = true, force = true})
            end

            -- Assert tactical state
            npc:set_mental_state(mental)
            npc:set_movement_type(move.run)
            npc:set_body_state(move.standing)
            
            -- [NEW] Clear any forced engine actions (shooting, sight)
            reset_npc_forced_actions(npc)
            
            -- Sound Feedback
            if xr_sound then xr_sound.set_sound_play(id, "panic_human") end
        end)

    -- [NEW] Drop Vanilla Looting Tasks (Forget current target)
    local st = db.storage[id]
    if st then
        -- 1. Gather Items Scheme
        if st.gather_items then
            st.gather_items.selected_obj_id = nil
            st.gather_items.selected_obj = nil
            st.gather_items.t_id = nil
        end
        -- 2. Corpse Detection Scheme
        if st.corpse_detection then
            st.corpse_detection.selected_corpse_id = nil
            st.corpse_detection.dtimer = nil -- Force reset timer
        end
    end

    -- 3. Register State
    active_states[id] = {
        type = "panic",
        end_time = time_global() + (duration or 5000),
        target_vid = vid,
        path_set = true, -- Marked as set since we did it above
        data = {
            danger_obj = danger_obj,
            forced = true
        }
    }
    
    -- Reset combat ticks
    battle_ticks[id] = 0
    
    -- Force sight reset
    npc:set_sight(look.cur_dir, nil, 0)
    
   end

-- ==============================================================================================
-- LOGIC UPDATES
-- ==============================================================================================

-- Specific update logic for PANIC state
local function update_panic_logic(npc, state_data)
    local id = npc:id()
    
    -- Check Expiration
    if time_global() > state_data.end_time then
        -- FINISH: Clear state and restore combat
        active_states[id] = nil
        
        if npc:best_enemy() then 
            npc:enable_memory_object(npc:best_enemy(), true) 
        end
        
               return
    end
    
    -- Check arrival at cover (stop running if reached)
    if state_data.target_vid then
        local current_vid = npc:level_vertex_id()
        local target_pos = level.vertex_position(state_data.target_vid)
        local dist = npc:position():distance_to(target_pos)
        
        if current_vid == state_data.target_vid or dist < 1.5 then
            -- Arrived at cover: crouch and wait
            npc:set_movement_type(move.stand)
            npc:set_body_state(move.crouch)
            state_data.arrived = true
            return
        end
    end
    
    -- Enforce State (Active Panic, still running)
    if not state_data.arrived then
        -- Assert parameters (Mental/Move only)
        local mental = anim.panic
        if siski_ef_utils.can_panic and not siski_ef_utils.can_panic(npc) then
            mental = anim.danger -- Fallback
        end

        pcall(function()
            npc:set_mental_state(mental)
            npc:set_movement_type(move.run)
        end)
        
        if not state_data.path_set and state_data.target_vid then
            -- Set path ONCE. Resetting destination every frame causes "stuttering"
            npc:set_path_type(game_object.level_path)
            npc:set_dest_level_vertex_id(state_data.target_vid)
            state_data.path_set = true
        end
    end
end

-- Generic State Processor
local function process_active_state(npc)
    local id = npc:id()
    local state = active_states[id]
    if not state then return end
    

    
    if state.type == "panic" then
        update_panic_logic(npc, state)
    elseif state.type == "crouch" then
        if time_global() > state.end_time then
            active_states[id] = nil
            -- Reset state?
            npc:set_body_state(move.standing)
            return
        end
        npc:set_body_state(move.crouch)
        
    elseif state.type == "cover" or state.type == "flank" then
        if time_global() > state.end_time then
            active_states[id] = nil
            return
        end
        
        -- Move to target
        if not state.path_set and state.target_vid then
             npc:set_path_type(game_object.level_path)
             npc:set_detail_path_type(move.line)
             npc:set_dest_level_vertex_id(state.target_vid)
             npc:set_movement_type(move.run)
             state.path_set = true
        end
        
        -- Check arrival
        if npc:level_vertex_id() == state.target_vid or npc:position():distance_to(level.vertex_position(state.target_vid)) < 1.0 then
             active_states[id] = nil -- Arrived
        end
    elseif state.type == "disarm" then
        -- Simple expiry
        if time_global() > state.end_time then
            active_states[id] = nil
        end
    end
end

-- ==============================================================================================
-- AGGRESSION & REFLEXES (Tuning)
-- ==============================================================================================

local function tune_npc_reflexes(npc)
    if not get_config("ef_aggression_enabled", true) then return end
    
    local id = npc:id()
    -- [PROTECTION] If NPC is in any active Siski state (Panic, Flank, etc.), skip reflexes
    if active_states[id] then return end

    local enemy = npc:best_enemy()
    if not siski_ef_utils.is_alive(enemy) then return end
    
    local wpn = npc:best_weapon()
    if not (wpn and IsWeapon(wpn)) then return end

    -- [PROTECTION] Do not interrupt critical engine animations (Reload, Misfire)
    local wpn_state = wpn:get_state()
    if wpn_state == 2 or wpn_state == 3 then -- 2=eReload, 3=eMisfire
        return 
    end

    -- 1. Force Aim Time (Engine parameter)
    local target_aim_time = get_config("ef_aim_time", 0)
    npc:aim_time(wpn, target_aim_time)

    -- 2. Combat FOV Boost
    if get_config("ef_forced_fov_enabled", true) then
        npc:set_fov(get_config("ef_forced_fov_value", 140))
    end

    -- 3. Near Awareness & Forced Aggression
    local dist = npc:position():distance_to(enemy:position())
    
    -- Force engine to notice enemies at point-blank range
    if get_config("ef_near_awareness_enabled", true) then
        local threshold = get_config("ef_near_awareness_dist", 7.0)
        if dist < threshold and not npc:see(enemy) then
             npc:make_object_visible_somewhen(enemy)
        end
    end

    if npc:see(enemy) then
        -- [NEW] Execution of wounded enemies
        if get_config("ef_execution_enabled", true) and IsWounded(enemy) then
             npc:set_sight(look.fire_point, enemy:position())
             npc:set_mental_state(anim.danger)
             -- Continuous fire until dead
             npc:set_item(object.fire1, wpn, 1, 1000)
             return -- Priority handled
        end

        -- [NEW] Forced Tracking for enemies in close range
        local track_dist = get_config("ef_near_track_dist", 5.0)
        if dist < track_dist then
             npc:set_sight(look.fire_point, enemy:position())
             npc:set_mental_state(anim.danger)
        end

        local chance = get_config("ef_aggro_fire_chance", 25)
        
        -- Scale aggression: NPCs react faster/harder if enemy is close
        if dist < 10 then chance = chance * 1.5 end
        if dist < 5 then chance = chance * 2.0 end

        if math.random(100) <= chance then
             -- Raised weapon and pointing at target
             npc:set_sight(look.fire_point, enemy:position())
             npc:set_mental_state(anim.danger)
             
             if math.random(100) > 50 then
                 -- Force a burst
                 npc:set_item(object.fire1, wpn, math.random(2, 4), math.random(100, 300))
             else
                 -- Just raise and let engine (reflexes-boosted) decide
                 npc:set_item(object.aim1, wpn)
             end
        end
    end
end


-- ==============================================================================================
-- DISPATCHERS
-- ==============================================================================================

local function on_npc_hit(npc, amount, local_direction, who, bone_index)
    if not npc then return end
    -- [OFFLINE/DEAD RESTRICTION] Ignore offline or dead NPCs
    if not (npc.online and siski_ef_utils.is_alive(npc)) then return end
    -- Only apply events to stalkers, not mutants
    if not IsStalker(npc) then return end
    
    -- Scope Check: Only work in meaningful battles
    if not is_meaningful_battle(npc) then return end
    
    
    local source = "unknown"
    
    if who then
        if who:id() == AC_ID then source = "actor"
        elseif IsStalker(who) then source = "stalker"
        elseif IsMonster(who) then source = "monster"
        end
    end
    
    local context = { source = source, amount = amount }
    
    -- Check Events (Priority Order) - with MCM enable checks
    
    local ef_ai_active = get_config("ef_enhanced_ai_enabled", true)
    
    if can_trigger_event(npc, "disarm", source) then
        if Events.Disarm:on_hit(npc, context) then return end
    end
    -- Rage/Crouch are distinct/cinematic, allowing them alongside AI (or maybe disable Crouch?)
    -- Crouch is "Survival", so `siski_ef_cover` might handle it better.
    -- Let's allow Disarm/Ambush always.
    
    if not ef_ai_active then
        -- Legacy Hit Reactions (only if Enhanced AI is OFF)
        if can_trigger_event(npc, "panic", source) then
            if Events.Panic:on_hit(npc, context) then return end
        end
        if can_trigger_event(npc, "crouch", source) then
            if Events.Crouch:on_hit(npc, context) then return end
        end
        if can_trigger_event(npc, "cover", source) then
            if Events.Cover:on_hit(npc, context) then return end
        end
        if can_trigger_event(npc, "flank", source) then
            if Events.Flank:on_hit(npc, context) then return end
        end
    end
end

local function on_npc_update(npc)
    -- [OFFLINE/DEAD RESTRICTION] Ignore offline or dead NPCs
    if not (npc and npc.online and siski_ef_utils.is_alive(npc)) then return end
    -- Only apply events to stalkers, not mutants
    if not IsStalker(npc) then return end
    
    -- [NEW] High Priority Grenade Panic (Priority 1)
    -- This MUST be checked before the battle scope, so neutral NPCs also flee!
    local danger = siski_ef_utils.safe_best_danger(npc)
    if danger then
        local d_type = danger:type()
        -- 0 is typically grenade/explosion in engine
        if d_type == danger_object.grenade or d_type == 0 then
            local d_obj = danger:object() or danger:perpetrator()
            if d_obj then
                local dist = npc:position():distance_to(d_obj:position())
                if dist < 15 then
                    force_panic_state(npc, d_obj, 5000) -- Flee for 5 seconds
                    return -- Exit update immediately to start fleeing
                end
            end
        end
    end
    
    -- Scope Check: Only work in meaningful battles (Allow finishing active states)
    local id = npc:id()
    if not active_states[id] and not is_meaningful_battle(npc) then 
        -- Cleanup forced states if they just recently left battle
        if battle_ticks[id] then
            npc:set_fov(90)
            battle_ticks[id] = nil
        end
        return 
    end


    -- 3. Process Active State (The Core Logic)
    if active_states[id] then
        process_active_state(npc)
        return -- Busy, don't trigger new things
    end
    
    -- 2. Register Combatant
    local best_enemy = npc:best_enemy()
    if best_enemy then
        -- Check validity of enemy object (fix for CSciptEntity crash)
        if siski_ef_utils.is_alive(best_enemy) then
            CombatManager:register(npc)
            CombatManager:register(best_enemy)
            
            -- 3. Battle Tick
            local now = time_global()
            if not battle_ticks[id] or (now - battle_ticks[id]) > 1000 then
                battle_ticks[id] = now
                
                local ef_ai_active = get_config("ef_enhanced_ai_enabled", true)
                
                -- ENHANCED AI INTEGRATION
                if ef_ai_active then
                    -- Call the OODA Loop
                    enhanced_ai.on_update(npc)
                    
                    -- Skip legacy Panic/Cover/Grenade logic as Enhanced AI handles them
                else
                    -- LEGACY LOGIC
                    if can_trigger_event(npc, "panic", nil) then
                        if Events.Panic:on_tick(npc) then return end
                    end
                    
                    -- GRENADE TICK (Per-NPC cooldown checked inside)
                    if can_trigger_event(npc, "grenade", nil) then
                        if Events.Grenade:on_tick(npc) then return end
                    end
                    
                    -- Cover/Flank logic was mostly hit-based, but could be added here if legacy is on
                end
            end
            
            -- TUNE REFLEXES (Every Update)
            tune_npc_reflexes(npc)
        end
    end
end



-- ==============================================================================================
-- CALLBACKS & PATCHES
-- ==============================================================================================

local function on_enemy_eval(obj, enemy, flags)
    if not obj then return end
    local state = active_states[obj:id()]
    if state then
        -- Only Ignore Enemies if Panicked or Disarmed
        -- Tactical states (Cover, Grenade, Flank, Crouch) MUST keep enemy memory to fight!
        if state.type == "panic" or state.type == "disarm" then
            flags.override = true
            flags.result = false
        end
    end
end

local function on_danger_eval(obj, flags)
    if not obj then return end
    local state = active_states[obj:id()]
    if state then
        if state.type == "panic" or state.type == "disarm" then
            flags.ret_value = false
        end
    end
end


local last_cleanup_time = 0

local function on_actor_update()
    if not db.actor then return end
    CombatManager:tick() -- Run the director
    
    -- Ambush logic (now handled via on_hit callback)
    
    local now = time_global()
    if now - last_cleanup_time > 60000 then
        last_cleanup_time = now
        for id, time in pairs(battle_ticks) do
             if now - time > 10000 then battle_ticks[id] = nil end
        end
    end
end

function on_game_start()
    RegisterScriptCallback("npc_on_hit_callback", on_npc_hit)
    RegisterScriptCallback("actor_on_update", on_actor_update)
    RegisterScriptCallback("npc_on_update", on_npc_update)
    RegisterScriptCallback("on_enemy_eval", on_enemy_eval)
    RegisterScriptCallback("npc_on_eval_danger", on_danger_eval)
    
    -- Anomaly cache will be handled on first update if needed
    
    -- Ensure Global Settings on Load
    RegisterScriptCallback("actor_on_first_update", function()
        get_console():execute("ai_die_in_anomaly 1")
    end)

	RegisterScriptCallback("npc_on_before_hit", function(npc, s_hit, bone_id, flags)
        -- Anomaly Protection (Integrated)
        -- DODANO: Sprawdzenie czy anomaly_handler nie jest nilem ORAZ czy posiada funkcję npc_on_before_hit
        if anomaly_handler and anomaly_handler.npc_on_before_hit and get_config("ef_enhanced_ai_enabled", true) then
             anomaly_handler.npc_on_before_hit(npc, s_hit, bone_id, flags)
        end
    end)

    RegisterScriptCallback("npc_on_death_callback", function(npc, who)
        if not npc then return end
        local id = npc:id()
        -- Cleanup all state tables
        active_states[id] = nil
        cooldowns[id] = nil
        battle_ticks[id] = nil
        grenade_cooldowns[id] = nil
        force_grenade_npcs[id] = nil
        
        -- Enhanced AI Cleanup
        if enhanced_ai and enhanced_ai.on_death then
            enhanced_ai.on_death(npc, who)
        end
    end)

    
    -- Monkey Patch Combat Ignore
    -- SETUP: Combat Ignore Patch
    if xr_combat_ignore and xr_combat_ignore.is_enemy then
        if not xr_combat_ignore.is_enemy_patched then
            local original = xr_combat_ignore.is_enemy
            xr_combat_ignore.is_enemy = function(obj, enemy, no_memory)
                if obj and obj.id then
                    local s = active_states[obj:id()] 
                    if s and (s.type == "panic" or s.type == "disarm") then return false end
                end
                if enemy and enemy.id then
                    local s = active_states[enemy:id()]
                    if s and (s.type == "panic" or s.type == "disarm") then return false end
                end
                return original(obj, enemy, no_memory)
            end
            xr_combat_ignore.is_enemy_patched = true
        end
    end

    -- Monkey Patch Weapon Jam
    -- [NEW] Disable NPC weapon jamming if enabled in MCM
    if xr_weapon_jam and get_config("ef_no_jam_enabled", true) then
        xr_weapon_jam.npc_on_update = function() end
           end

    
    -- Setup Global AI Settings
    get_console():execute("ai_die_in_anomaly 1")
   
end

if bind_stalker and bind_stalker.update then
    pcall(require, "siski_ef_doctrine_overlay")
end
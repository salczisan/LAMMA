-- ==============================================================================================
-- SISKI EPIC FIGHT MODULE
-- Dynamic npc reactions in gunfights system
-- ==============================================================================================

-- Helper to get MCM config
function get_config(key, default)
    if ui_mcm then
        return ui_mcm.get("siski_ef/"..key) or default
    end
    return default
end


local cooldowns = {}        -- [npc_id] = last_trigger_time
local battle_ticks = {}     -- [npc_id] = last_tick_time
local active_states = {}    -- [npc_id] = { type="panic", end_time=..., data={} }

-- GRENADE EVENT STATE TABLES
local grenade_cooldowns = {}   -- [npc_id] = time_global() when cooldown expires (per-NPC, per-event)
local force_grenade_npcs = {}  -- [npc_id] = grenade_game_object to force via hook
function on_grenade_nearby(npc, grenade)
    local id = npc:id()
    local tg = time_global()
    
    if grenade_cooldowns[id] and tg < grenade_cooldowns[id] then return end
    
    -- Szukaj vertexu ucieczki (wykorzystaj find_tactical_cover)
    local escape_vid = find_tactical_cover(npc)
    if escape_vid then
        npc:set_dest_level_vertex_id(escape_vid)
        state_mgr.set_state(npc, "assault", nil, nil, nil, {fast_set = true})
        grenade_cooldowns[id] = tg + 5000 -- Nie reaguj na co sekundę
    end
end


local AC_ID = 0
local CombatManager -- Forward declaration
local enhanced_ai = siski_epic_fight_enhanced_ai -- Module reference
local anomaly_handler = siski_ef_anomaly -- Anomaly Handler reference

-- ==============================================================================================
-- SHARED HELPERS (Reusable)
-- ==============================================================================================

-- Find a safe spot to run to (Cover > Direction > Current)
local function find_tactical_cover(npc)
    if not npc then return nil end
    local actor = db.actor
    if not actor then return nil end

    local npc_pos = npc:position()
    local actor_pos = actor:position()
    
    local cover = npc:best_cover(npc_pos, actor_pos, 30, 10, 20)
    
    if cover then
        local cover_vid = cover:level_vertex_id()
        if cover_vid and cover_vid < 4294967295 and npc:accessible(cover_vid) then
            return cover_vid
        end
    end
    
    local dir = vector():set(npc_pos.x - actor_pos.x, 0, npc_pos.z - actor_pos.z)
    dir:normalize()
    local distances = {20, 15, 10}
    for _, dist in ipairs(distances) do
        local target_pos = vector():set(npc_pos.x + dir.x * dist, npc_pos.y, npc_pos.z + dir.z * dist)
        local vid = level.vertex_id(target_pos)
        if vid and vid < 4294967295 and npc:accessible(vid) then
            return vid
        end
    end
    
    return npc:level_vertex_id()
end

-- Drop active weapon and safely delete it (returns section name)
local function force_drop_weapon(npc)
    local item = npc:active_item()
    if not item or not item:id() then return nil end
    
    local sec = item:section()
    local item_id = item:id()
    local npc_id = npc:id()
    local se_item = alife_object(item_id)
    
    if se_item and se_item.parent_id == npc_id then
        -- SIMPLE HOLSTER (User Request)
        -- Just put it away. No drop. No delete.
        npc:set_item(object.idle, item)
                return sec
    end
    return nil
end

-- Create item safely on NPC
local function alife_create_item(section, npc)
    if not npc or not section then return nil end
    return alife():create(section, npc:position(), npc:level_vertex_id(), npc:game_vertex_id(), npc:id())
end

-- Force stop any SISKI-driven engine actions (bursts, sight overrides)
local function reset_npc_forced_actions(npc)
    if not npc then return end
    local wpn = npc:best_weapon()
    if wpn and IsWeapon(wpn) then
        npc:set_item(object.idle, wpn)
    end
    -- Reset sight to default (look in movement direction)
    npc:set_sight(look.cur_dir, nil, 0)
    -- Reset FOV to standard level
    npc:set_fov(90)
    
   
end


-- ==============================================================================================
-- BATTLE SCOPE (Meaningful Battles)
-- ==============================================================================================

local function is_meaningful_battle(npc)
    local actor = db.actor
    if not actor then return false end
    
    local id = npc:id()
    local is_actor = (id == AC_ID)
    
    -- 1. Direct relevance: is actor involved in THIS NPC's battle?
    -- OR: if this is actor, is there ANY battle with actor and enemies?
    local ctx = CombatManager:get_context(npc)
    if ctx then
        -- If actor is in the same cluster, it's meaningful
        for _, b in ipairs(CombatManager.battles) do
            if b.members[id] and b.members[AC_ID] then
                -- For actor, check if there are actual enemies in this cluster
                if is_actor then
                    for comm, count in pairs(b.factions) do
                        if comm ~= "actor" then return true end
                    end
                else
                    return true 
                end
            end
        end
    end
    
    -- 2. Proximity: is battle happening near actor? (ONLY for NPCs)
    -- If we check this for actor, distance is always 0, leading to bugs.
    if not is_actor then
        local pos = npc:position()
        local actor_pos = actor:position()
        if pos:distance_to(actor_pos) < 150 then
            return true
        end
    end
    
    return false
end

CombatManager = {
    -- Registry of all active combatants [id] = {npc = obj, time = global_time}
    combatants = {},
    -- Clustered battles [1..N] = { center=vec3, radius=50, members={id=true}, factions={} }
    battles = {},
    last_tick = 0,

    -- Register or update an NPC as "In Combat"
    register = function(self, npc)
        self.combatants[npc:id()] = { npc = npc, time = time_global() }
    end,
    
    -- Main loop: Form clusters (Every 2s)
    tick = function(self)
        local now = time_global()
        if now - self.last_tick < 2000 then return end
        self.last_tick = now
        
        -- 1. Prune dead/afk combatants (older than 3s)
        for id, data in pairs(self.combatants) do
            if now - data.time > 3000 or not siski_ef_utils.is_alive(data.npc) then
                self.combatants[id] = nil
            end
        end
        
        -- 2. Cluster
        self.battles = {}
        local assigned = {} -- [id] = true
        
        for id, data in pairs(self.combatants) do
            if not assigned[id] then
                -- Start a new battle cluster
                local center = data.npc:position()
                local new_battle = {
                    center = center,
                    members = { [id] = data.npc },
                    factions = {} -- [comm] = count
                }
                assigned[id] = true
                
                -- Greedy search for neighbors
                for other_id, other_data in pairs(self.combatants) do
                    if not assigned[other_id] then
                        if center:distance_to(other_data.npc:position()) < 60 then
                            new_battle.members[other_id] = other_data.npc
                            assigned[other_id] = true
                        end
                    end
                end
                
                -- Calculate Stats
                for m_id, m_npc in pairs(new_battle.members) do
                    local comm = "monster"
                    
                    if m_id == AC_ID then
                        comm = "actor"
                    elseif IsStalker(m_npc) then
                        comm = m_npc:character_community()
                    end
                    
                    new_battle.factions[comm] = (new_battle.factions[comm] or 0) + 1
                end
                
                table.insert(self.battles, new_battle)
            end
        end
        
        if #self.battles > 0 then
            -- Optional debug
                    end
    end,
    
    -- Get context for a specific NPC
    get_context = function(self, npc)
        -- Find which battle this NPC is in
        local battles = self.battles
        local my_battle = nil
        local id = npc:id()
        
        for _, b in ipairs(battles) do
            if b.members[id] then
                my_battle = b
                break
            end
        end
        
        if not my_battle then return nil end
        
        -- Analyze
        local my_comm = "monster"
        if id == AC_ID then my_comm = "actor"
        elseif IsStalker(npc) then my_comm = npc:character_community() end
        
        local allies = my_battle.factions[my_comm] or 0
        local enemies = 0
        
        -- Sum up all other communities as enemies (simplification, assume hostility in combat)
        -- Ideally checks relation, but community check is faster for aggregation
        for comm, count in pairs(my_battle.factions) do
            if comm ~= my_comm then
                enemies = enemies + count
            end
        end
        
        return {
            total_combatants = (allies + enemies),
            allies = allies,
            enemies = enemies,
            outnumbered = (enemies > allies)
        }
    end
}

-- ==============================================================================================
-- CHECK LOGIC (Encapsulated)
-- ==============================================================================================

local function can_trigger_event(npc, event_id, source_type)
    -- 1. Global Enable
    if not get_config("ef_enabled", true) then return false end
    
    -- 2. Event Enable
    if not get_config("ef_" .. event_id .. "_enabled", true) then return false end
    
    -- 3. Active State Check (IMMUNITY)
    -- If NPC is in ANY active event (Panic, Rage, whatever), they cannot trigger new ones.
    if npc and active_states[npc:id()] then return false end
    
    -- 4. Source Check
    if source_type then
        local allowed = get_config("ef_" .. event_id .. "_src_" .. source_type, true)
        if not allowed then return false end
    end
    
    return true
end

-- ==============================================================================================
-- DEEP PLANNER INJECTION REMOVED (Reverted by User Request)
-- ==============================================================================================

local Events = {}

-- PANIC EVENT
Events.Panic = {
    id = "panic",
    
    action = function(self, npc)
        if active_states[npc:id()] then return false end
        
        -- [PROTECTION] Clear any Aggro-Fire/Reflexes states before starting tactical move
        reset_npc_forced_actions(npc)
        
        local vid = nil
        
        -- Use Unified Flee Logic if available
        if siski_ef_flee then
            local danger_obj = npc:best_enemy() or db.actor
            vid = siski_ef_flee.find_flee_vertex(npc, danger_obj)
        else
            -- Fallback
            vid = find_tactical_cover(npc)
        end
        
        if not vid then return false end
        
        local min_dur = get_config("ef_panic_dur_min", 1)
        local max_dur = get_config("ef_panic_dur_max", 5)
        local duration = math.random(min_dur * 1000, max_dur * 1000)
        
        -- Store State in UNIFIED table
        active_states[npc:id()] = {
            type = "panic",
            end_time = time_global() + duration,
            target_vid = vid,
            path_set = false
        }
        
        -- OPTIMIZATION: Clear animations for INSTANT transition (no waiting for current anim)
        npc:clear_animations()
        
        -- Holster weapon (optional)
        if get_config("ef_panic_drop_wep", true) then
            force_drop_weapon(npc)
        end
        
        -- Safe sound call
        if xr_sound and xr_sound.set_sound_play then
            xr_sound.set_sound_play(npc:id(), "panic_human")
        end
        
        -- Movement commands (order matters for responsiveness)
        npc:set_path_type(game_object.level_path)
        npc:set_detail_path_type(move.line)
        npc:set_dest_level_vertex_id(vid)
        npc:set_mental_state(anim.panic)
        npc:set_movement_type(move.run)
        
                return true
    end,
    
    on_hit = function(self, npc, context)
        local chance = get_config("ef_panic_on_hit", 5)
        
        -- Dynamic logic from CombatManager
        local battle_ctx = CombatManager:get_context(npc)
        if battle_ctx and battle_ctx.outnumbered then
            chance = chance * 1.5 -- 50% more likely to panic if outnumbered
        end
        
        -- Monster Multiplier
        if context.source == "monster" then
             chance = chance * get_config("ef_panic_monster_mult", 3)
        end
        
        if math.random(100) <= chance then
            return self:action(npc)
        end
        return false
    end,
    
    on_tick = function(self, npc)
        local chance = get_config("ef_panic_on_tick", 2)
        
        -- Panic if heavily outnumbered on tick
        local battle_ctx = CombatManager:get_context(npc)
        if battle_ctx and battle_ctx.enemies > (battle_ctx.allies * 2) then
             chance = chance * 2 
        end
        
        if math.random(100) <= chance then
            return self:action(npc)
        end
        return false
    end
}

-- DISARM EVENT
Events.Disarm = {
    id = "disarm",
    action = function(self, npc)
        if active_states[npc:id()] then return false end
        
        -- [PROTECTION] Stop shooting for disarm
        reset_npc_forced_actions(npc)
        
        -- Simple Drop (User Request: "without complexities")
        local item = npc:active_item()
        
        -- STRICT CHECK: Must have an item, and it must be a weapon
        if not item or (IsWeapon and not IsWeapon(item)) then 
            return false 
        end
        
        local sec = item:section()
        local item_id = item:id()
        local npc_id = npc:id()
        
        -- Minimal safety: Defer drop to next frame to avoid engine iterator crash
        CreateTimeEvent("ef_simple_disarm_"..item_id, item_id, 0, function()
            local npc_obj = level.object_by_id(npc_id)
            local item_obj = level.object_by_id(item_id)
            
            local item_obj = level.object_by_id(item_id)
            if siski_ef_utils.is_alive(npc_obj) and item_obj then
                 npc_obj:drop_item(item_obj)
                             end
            return true
        end)
        
        -- Register Active State (User Request: 2s timer)
        active_states[npc_id] = {
            type = "disarm",
            end_time = time_global() + 2000
        }

        return true
    end,
    on_hit = function(self, npc, context)
        local chance = get_config("ef_disarm_on_hit", 1)
        if math.random(100) <= chance then
            return self:action(npc)
        end
        return false
    end,
    on_tick = function(self, npc) return false end
}

-- AMBUSH EVENT (Mutant Spawn behind Actor)
local session_ambush_cd = 0
local last_ambush_check = 0

Events.Ambush = {
    id = "ambush",
    action = function(self)
        local actor = db.actor
        if not actor then return false end
        
        -- [REMOVED v3] Combat check - Ambush should start the combat.

        -- Night Check (approx 23:00 to 06:00)
        local hour = level.get_time_hours()
        if hour > 6 and hour < 23 then return false end
        
        -- Cooldown Check
        local last_ambush = session_ambush_cd
        if utils_obj and utils_obj.load_var then
            local saved = utils_obj.load_var(actor, "siski_ef_ambush_cd") or 0
            if saved > last_ambush then last_ambush = saved end
        end
        
        if time_global() < last_ambush then return false end -- blocked

        -- Calculate Position (Behind Actor, 7-10m)
        local dir = actor:direction()
        dir:mul(-1) -- backwards
        dir = vector_rotate_y(dir, math.random(-30, 30)) -- slight variation
        
        local dist = math.random(7, 10)
        local pos = actor:position()
        pos:add(dir:mul(dist))
        
        local vid = level.vertex_id(pos)
        if not vid or vid >= 4294967295 or not actor:accessible(vid) then
             -- Try closer
             vid = actor:level_vertex_id()
             pos = actor:position()
        end
        
        -- Spawn
        local section = (math.random() > 0.5) and "simulation_chimera" or "simulation_bloodsucker"
        local se_obj = alife():create(section, pos, vid, actor:game_vertex_id())
        
        if se_obj then
                          
             -- [NEW] Squad Initialization (Bypassing engine limits)
             if SIMBOARD and SIMBOARD.setup_squad_and_group then
                 SIMBOARD:setup_squad_and_group(se_obj)
             end
             
             -- If it's a squad (expected), force create NPCs
             if se_obj.create_npc then
                 se_obj:create_npc(nil, pos, vid, actor:game_vertex_id())
             end

             -- [NEW] Force Aggression: Make mutant target the player after spawn
             CreateTimeEvent("ef_ambush_aggro_"..se_obj.id, se_obj.id, 0.5, function()
                 local obj = level.object_by_id(se_obj.id)
                 if obj and obj:alive() then
                     obj:make_object_visible_somewhen(actor)
                     return true
                 end
                 return false
             end)
             
             -- Set Cooldown (configurable real time hours)
             local cd_hours = get_config("ef_ambush_cooldown", 3)
             local cd = cd_hours * 3600 * 1000
             session_ambush_cd = time_global() + cd
             
             if utils_obj and utils_obj.save_var then
                 utils_obj.save_var(actor, "siski_ef_ambush_cd", session_ambush_cd)
             end
             return true
        end
        return false
    end,
    
    on_hit = function(self, actor, context)
        -- Ambush Event Triggered via actor_on_hit_callback
        -- 1. Configuration Check
        if get_config("ef_ambush_enabled", true) == false then return false end
        
        -- 2. Night Time Restriction (21:00 - 05:00)
        local h = level.get_time_hours()
        if (h >= 5 and h < 21) then return false end
        
        -- 3. Cooldown Check (Using saved/session variable)
        if time_global() < session_ambush_cd then return false end
        
        -- 4. Throttle (Don't check every single hit if player is being sprayed)
        local now = time_global()
        if now < last_ambush_check then return false end
        last_ambush_check = now + 5000 -- 5s throttle between chance checks
        
        -- 5. Trigger Chance
        if math.random(100) <= get_config("ef_ambush_chance", 1) then
            return self:action()
        end
        return false
    end
}

-- CROUCH EVENT
Events.Crouch = {
    id = "crouch",
    action = function(self, npc)
        if active_states[npc:id()] then return false end
        
        -- [PROTECTION] Stop forced sight/burts
        reset_npc_forced_actions(npc)
        
        local duration = math.random(1000, 5000)
        
        active_states[npc:id()] = {
            type = "crouch",
            end_time = time_global() + duration
        }
        
        npc:clear_animations() -- Instant transition
        npc:set_body_state(move.crouch)
        npc:set_movement_type(move.run) -- can still move/shoot while crouching?
        -- Actually, usually state enforcement handles this.
        
                return true
    end,
    on_hit = function(self, npc, context)
        local chance = get_config("ef_crouch_on_hit", 10)
        if math.random(100) <= chance then return self:action(npc) end
        return false
    end
}


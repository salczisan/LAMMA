local path_builder = function(key)
    local tab = key_to_tab[key]
    return tab and ("ap/" .. tab .. "/" .. key) or nil
end
get_config = xmcm.create_getter("ap", defaults, path_builder)
cfg = setmetatable({}, { __index = function(_, k)
    return get_config(k)
end })

local function slide(txt)
    return {
        id = "title", type = "slide", link = "ui_options_slider_player",
        text = txt, size = { 512, 50 }, spacing = 20
    }
end

local function desc(txt)
    return { id = "desc", type = "desc", text = txt }
end

local function check(key, def)
    return { id = key, type = "check", val = 1, def = def }
end

local function track(key, mn, mx, st, def)
    return { id = key, type = "track", val = 2, min = mn, max = mx, step = st, def = def }
end

local function list(key, def, content)
    return { id = key, type = "list", val = 0, def = def, content = content }
end


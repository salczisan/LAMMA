    <!-- ==================== GENERAL TAB ==================== -->
    <string id="ui_mcm_ap_general_title">
        <text>General Settings</text>
    </string>
    <string id="ui_mcm_ap_version">
        <text>%c[d_cyan]1.1.0</text>
    </string>
    <string id="ui_mcm_ap_general_desc">
        <text>Flow control for the AlifePlus event system. Events pass through a distributor, map ratio gate, cooldown, and per-key sliding windows before firing. Causes detect patterns, consequences react. Zero cost when idle.</text>
    </string>
    <string id="ui_mcm_ap_general_going_speed">
        <text>Going Speed</text>
    </string>
    <string id="ui_mcm_ap_general_going_speed_desc">
        <text>X-Ray processes A-Life at two speeds: per-frame on your level, round-robin on distant levels. This applies the same split to incoming X-Ray events, gating all downstream causes and consequences. Slider sets how many out of 10 event slots go to your map (8 = ratio 4:1 favoring on-map, 0 = equal, negative = off-map favored). On-map and off-map have separate cooldowns.</text>
    </string>

    <string id="ui_mcm_ap_general_distributor_max_xray_events">
        <text>Distributor: max X-Ray events per window</text>
    </string>
    <string id="ui_mcm_ap_general_distributor_max_xray_events_desc">
        <text>How many raw engine events each callback type can process per window. Radiant callbacks (smart transitions) get double budget. Acts as the first gate -- everything downstream only runs if this budget allows.</text>
    </string>
    <string id="ui_mcm_ap_general_distributor_window_sec">
        <text>Distributor: window (sec)</text>
    </string>
    <string id="ui_mcm_ap_general_distributor_window_sec_desc">
        <text>Time window for the distributor budget.</text>
    </string>
    <string id="ui_mcm_ap_general_global_cause_lock_sec">
        <text>Global cause lock (sec)</text>
    </string>
    <string id="ui_mcm_ap_general_global_cause_lock_sec_desc">
        <text>Cooldown after a cause fires. On-map and off-map have separate cooldowns, so distant events never affect your map.</text>
    </string>
    <string id="ui_mcm_ap_general_cause_window_max_events">
        <text>Max cause events per window</text>
    </string>
    <string id="ui_mcm_ap_general_cause_window_max_events_desc">
        <text>How many times each cause type can fire per window. Prevents any single cause from dominating.</text>
    </string>
    <string id="ui_mcm_ap_general_cause_window_sec">
        <text>Cause window (sec)</text>
    </string>
    <string id="ui_mcm_ap_general_cause_window_sec_desc">
        <text>Time window for per-cause budgets.</text>
    </string>
    <string id="ui_mcm_ap_general_consequence_window_max_events">
        <text>Max consequence events per window</text>
    </string>
    <string id="ui_mcm_ap_general_consequence_window_max_events_desc">
        <text>How many times each consequence can fire per window. Prevents reaction spam during heavy combat.</text>
    </string>
    <string id="ui_mcm_ap_general_consequence_window_sec">
        <text>Consequence window (sec)</text>
    </string>
    <string id="ui_mcm_ap_general_consequence_window_sec_desc">
        <text>Time window for per-consequence budgets.</text>
    </string>

    <!-- ==================== A-LIFE TRACKER TAB ==================== -->
    <string id="ui_mcm_ap_alife_tracker_title">
        <text>A-Life Tracker</text>
    </string>
    <string id="ui_mcm_ap_alife_tracker_desc">
        <text>Persistent registry for AlifePlus. Tracks kills, promotions, scripted squads, and conquered areas. Survives save/load. Periodic sync is a failsafe for stale entries caused by badly written mods interacting with the system.</text>
    </string>
    <string id="ui_mcm_ap_alife_tracker_alife_periodic_sync_enabled">
        <text>Periodic sync (failsafe)</text>
    </string>
    <string id="ui_mcm_ap_alife_tracker_alife_periodic_sync_enabled_desc">
        <text>Enable periodic cleanup of stale entries. Belt-and-suspenders failsafe.</text>
    </string>
    <string id="ui_mcm_ap_alife_tracker_alife_sync_interval">
        <text>Sync interval (seconds)</text>
    </string>
    <string id="ui_mcm_ap_alife_tracker_alife_sync_interval_desc">
        <text>How often to scan for stale entries (300-1800 seconds).</text>
    </string>


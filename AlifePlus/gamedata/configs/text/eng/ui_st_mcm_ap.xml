    </string>
    <string id="ui_mcm_ap_consequences_elitekill_bounty_consequence_elitekill_bounty_enabled_desc">
        <text>Reward killer with rubles when an elite dies.</text>
    </string>
    <string id="ui_mcm_ap_consequences_elitekill_bounty_consequence_elitekill_bounty_base">
        <text>Base reward per level (RU)</text>
    </string>
    <string id="ui_mcm_ap_consequences_elitekill_bounty_consequence_elitekill_bounty_base_desc">
        <text>Rubles per elite level. At 1000 RU/level, killing a level 5 elite = 5000 RU.</text>
    </string>
    <string id="ui_mcm_ap_consequences_elitekill_bounty_consequence_elitekill_bounty_max">
        <text>Maximum reward (RU)</text>
    </string>
    <string id="ui_mcm_ap_consequences_elitekill_bounty_consequence_elitekill_bounty_max_desc">
        <text>Cap on total bounty reward.</text>
    </string>
    <string id="ui_mcm_ap_consequences_elitekill_bounty_consequence_elitekill_bounty_pda_chance">

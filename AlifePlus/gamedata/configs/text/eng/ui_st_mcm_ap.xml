    </string>
    <string id="ui_mcm_ap_consequences_elitekill_bounty_desc">
        <text>When the EliteKill cause fires, rewards the killer. Both player and NPC killers receive rubles scaled by the elite's level.</text>
    </string>
    <string id="ui_mcm_ap_consequences_elitekill_bounty_consequence_elitekill_bounty_enabled">

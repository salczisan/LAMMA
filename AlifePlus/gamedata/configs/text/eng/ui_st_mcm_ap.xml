    <string id="ui_mcm_ap_consequences_elitekill_bounty_consequence_elitekill_bounty_pda_chance_desc">
        <text>Chance to notify when bounty is claimed. 0 = disabled.</text>
    </string>

    <!-- ==================== CONSEQUENCES / ELITEKILL TARGETED ==================== -->

    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_elite_grenade_restock_cooldown_hours_desc">
        <text>Real-time hours between grenade restocks per NPC.</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_elite_ap_ammo_enabled">
        <text>AP ammo restock enabled</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_elite_ap_ammo_enabled_desc">
        <text>Give best armor-piercing ammo for the elite's weapon when hit. Boxes scale by level.</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_elite_ap_ammo_cooldown_hours">

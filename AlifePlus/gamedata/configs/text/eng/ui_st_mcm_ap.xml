    <!-- ==================== CONSEQUENCES / ELITE PROMOTE ==================== -->
    <string id="ui_mcm_ap_consequences_elite_promote_title">
        <text>Elite\nPromote</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_desc">
        <text>When the Elite cause fires, registers the NPC as elite. Includes rank boost, grenade restock, and AP ammo restock scaled by elite level (1-10).</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_consequence_elite_promote_enabled">
        <text>Enabled</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_consequence_elite_promote_enabled_desc">
        <text>Register stalkers as elites when they level up from kills.</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_max_elites">
        <text>Maximum elites</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_max_elites_desc">
        <text>Maximum number of elites allowed worldwide. Only blocks new elites, not level-ups.</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_consequence_elite_promote_pda_chance">
        <text>PDA notification chance (%)</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_consequence_elite_promote_pda_chance_desc">
        <text>Chance to broadcast PDA message when an elite levels up.</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_rank_boost_enabled">
        <text>Rank boost enabled</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_rank_boost_enabled_desc">
        <text>Boost engine rank for elites based on level. Higher rank improves NPC accuracy by up to 20%.</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_elite_grenade_restock_enabled">
        <text>Grenade restock enabled</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_elite_grenade_restock_enabled_desc">
        <text>Give grenades to elite stalkers when hit. Count equals elite level (1-10).</text>
    </string>
    <string id="ui_mcm_ap_consequences_elite_promote_elite_grenade_restock_cooldown_hours">
